---
import {getSiteSettings} from '../scripts/getSettings';
import {getBusinessHours} from '../scripts/getBusinessHours';
import {Image} from 'astro:assets';
import logoImage from '../assets/tt-logo-2026.png';

const settings = await getSiteSettings();
const businessHours = getBusinessHours(settings);

const currentYear = new Date().getFullYear();
---
<footer class="bg-brand-dark text-white py-12 md:py-16">
    <div class="layout-container">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">

            {/* Kolonne 1: Logo + beskrivelse */}
            <div>
                <Image
                    src={logoImage}
                    alt="Tenner og Trivsel"
                    width={180}
                    class="h-12 w-auto object-contain mb-4 brightness-0 invert"
                    loading="lazy"
                />
                <p class="text-white/70 text-sm leading-relaxed">
                    Din tannklinikk for trygg og god behandling.
                    Vi kombinerer faglig dyktighet med omsorg for å
                    gi deg den beste opplevelsen.
                </p>
            </div>

            {/* Kolonne 2: Kontaktinfo */}
            <div>
                <h3 class="font-heading font-semibold text-sm uppercase tracking-wider mb-4">Kontakt</h3>
                <div class="space-y-2 text-white/70 text-sm">
                    <p>{settings.adresse1}</p>
                    <p>{settings.adresse2}</p>
                    <p class="pt-2">
                        <a href={`tel:${settings.phone1?.replace(/\s+/g, '')}`} class="hover:text-white transition-colors">
                            {settings.phone1}
                        </a>
                    </p>
                    {settings.phone2 && (
                        <p>
                            <a href={`tel:${settings.phone2?.replace(/\s+/g, '')}`} class="hover:text-white transition-colors">
                                {settings.phone2}
                            </a>
                        </p>
                    )}

                    {settings.showEmail === "ja" && settings.email && (
                        <p class="pt-2">
                            <a href={`mailto:${settings.email}`} class="hover:text-white transition-colors">
                                {settings.email}
                            </a>
                        </p>
                    )}

                </div>
            </div>

            {/* Kolonne 3: Åpningstider */}
            {businessHours.length > 0 && (
                <div>
                    <h3 class="font-heading font-semibold text-sm uppercase tracking-wider mb-4">Åpningstider</h3>
                    <dl class="grid grid-cols-[auto_auto] gap-x-2 gap-y-1 text-white/70 text-sm w-fit">
                        {businessHours.map(text => {
                            const i = text.indexOf(':');
                            if (i === -1) return <dd class="col-span-2">{text}</dd>;
                            const day = text.substring(0, i).trim();
                            const time = text.substring(i + 1).trim();
                            return <><dt class="font-medium">{day}</dt><dd class="tabular-nums text-left">{time}</dd></>;
                        })}
                    </dl>
                </div>
            )}
        </div>

        {/* Copyright-linje */}
        <div class="border-t border-accent mt-10 pt-6 text-center text-white/50 text-xs">
            <p>&copy; {currentYear} Tenner og Trivsel · <a href="/prisliste" class="hover:text-white transition-colors underline">Prisliste</a> · <a href="/personvern" class="hover:text-white transition-colors underline">Personvern</a></p>
        </div>
    </div>
</footer>
