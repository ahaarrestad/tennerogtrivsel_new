---
import {getCollection} from 'astro:content';
import Card from './Card.astro';
import { getSiteSettings } from '../scripts/getSettings';
import { getSectionClasses, type SectionVariant } from '../scripts/sectionVariant';
import SectionHeader from './SectionHeader.astro';

// 1. Hent alle filene fra src/content/tjenester/
const allServices = await getCollection('tjenester');

// 2. Sorter dem alfabetisk basert på tittelen i frontmatter (nb = norsk)
const sortedServices = allServices.sort((a, b) =>
    a.data.title.localeCompare(b.data.title, 'nb')
);
const settings = await getSiteSettings();

interface Props { variant?: SectionVariant }
const { variant = 'white' } = Astro.props;
const { sectionBg, headerBg } = getSectionClasses(variant);
---
<section id="tjenester" class={`section-container ${sectionBg}`}>
    <div class="section-content">
        <SectionHeader title={settings.tjenesterTittel} intro={settings.tjenesteTekst} headerBg={headerBg} sticky />

        <div class="card-grid gap-6 md:gap-8">
            {sortedServices.map((service, index) => (
                    <Card
                            index={index}
                            title={service.data.title}
                            headerOffset="150px"
                            minHeight="250px"
                            centered={false}
                            isStack={true}
                            href={`/tjenester/${service.id}`}
                    >
                        <p class="card-text line-clamp-3">
                            {service.data.ingress}
                        </p>
                    </Card>
            ))}
        </div>
    </div>
</section>