---
import {formatInfoText} from "../scripts/textFormatter";
import {getSiteSettings} from '../scripts/getSettings';
import { getSectionClasses, type SectionVariant } from '../scripts/sectionVariant';
import SectionHeader from './SectionHeader.astro';
import Card from "./Card.astro";
import { getEntry } from 'astro:content';
import ContactButton from './ContactButton.astro';

import {getBusinessHours} from '../scripts/getBusinessHours';

const settings = await getSiteSettings();

const lat = settings.latitude;
const lng = settings.longitude;

const minHeight = "250px";

const googleMapsDirectionUrl = `https://www.google.com/maps/search/?api=1&query=${lat},${lng}`;

const businessHours = getBusinessHours(settings, ["Ta kontakt for åpningstider"]);

const ksEntry = await getEntry('kontaktskjema', 'kontaktskjema');
const kontaktskjema = ksEntry?.data ?? { aktiv: false,tittel: '', tekst: '' };

interface Props { variant?: SectionVariant }
const { variant = 'brand' } = Astro.props;
const { sectionBg, headerBg } = getSectionClasses(variant);
---
<section id="kontakt" class={`section-container ${sectionBg}`}>
    <div class="section-content">

        <SectionHeader title={settings.kontaktTittel} intro={settings.kontaktTekst} headerBg={headerBg} sticky />

        <div class={`grid grid-cols-1 md:grid-cols-2 ${kontaktskjema.aktiv ? 'lg:grid-cols-4' : 'lg:grid-cols-3'} gap-8 mb-24 relative z-10`}>
            {/* Åpningstid-boks */}
            <Card index="0"
                  title="Åpningstider"
                                   minHeight={minHeight}>
                <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <dl class="grid grid-cols-[auto_auto] justify-center gap-x-6 gap-y-1.5 w-full">
                    {businessHours.map(text => {
                        const i = text.indexOf(':');
                        if (i === -1) return <dd class="col-span-2 text-center">{text}</dd>;
                        const day = text.substring(0, i).trim();
                        const time = text.substring(i + 1).trim();
                        return <><dt class="font-medium text-left">{day}</dt><dd class="tabular-nums text-left">{time}</dd></>;
                    })}
                </dl>
            </Card>


            <Card
                    index="2"
                    title="Besøksadresse"
                                       minHeight={minHeight}
                    href={googleMapsDirectionUrl}
                    centered={true}
                    external={true}>
                <svg slot="icon"
                     xmlns="http://www.w3.org/2000/svg"
                     width="32"
                     height="32"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="2"
                     stroke-linecap="round"
                     stroke-linejoin="round"
                     aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                </svg>
                <p>{settings.adresse1}</p>
                <p>{settings.adresse2}</p>

                <div slot="link">
                    <div class="card-link">
                        Få veibeskrivelse <span class="ml-2 transition-transform group-hover:translate-x-1 inline-block">→</span>
                    </div>
                </div>
            </Card>

            <Card index="4"
                  title="Telefon"
                                   minHeight={minHeight}>
                <svg slot="icon"
                     xmlns="http://www.w3.org/2000/svg"
                     width="32"
                     height="32"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="2"
                     stroke-linecap="round"
                     stroke-linejoin="round"
                     aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.21-2.21a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
                <p><span set:html={formatInfoText(settings.phone1)}></span></p>
                <p class="text-xs">{settings.sentralbordTekst}</p>

            </Card>

            {/* Kontaktskjema - hvis aktivert */}
            {kontaktskjema.aktiv && (
                    <Card index="6" title={kontaktskjema.tittel} minHeight={minHeight}>
                        <svg slot="icon"
                             xmlns="http://www.w3.org/2000/svg"
                             width="32"
                             height="32"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round"
                             aria-hidden="true">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                        <div slot="link" class="flex justify-center">
                            <ContactButton />
                        </div>
                    </Card>
            )}

        </div>

        <div class="relative w-full mb-20 z-0">
            <div id="map"
                 data-lat={lat}
                 data-lng={lng}
                 data-name="Tenner og Trivsel"
                 class="w-full h-[450px] md:h-[550px] rounded-2xl overflow-hidden shadow-xl border border-brand-border"
                 role="application"
                 aria-label="Kart som viser klinikkens plassering"></div>
            <div class="flex justify-center mt-4">
                <a href={googleMapsDirectionUrl}
                   target="_blank"
                   rel="noopener noreferrer"
                   class="btn-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polygon points="3 11 22 2 13 21 11 13 3 11"></polygon>
                    </svg>
                    Få veibeskrivelse
                </a>
            </div>
        </div>
    </div>
</section>

<script>
    import { initMap } from '../scripts/mapInit';
    initMap();
</script>
