---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { getSiteSettings } from '../scripts/getSettings';
import { getSectionClasses, type SectionVariant } from '../scripts/sectionVariant';
import SectionHeader from './SectionHeader.astro';

const galleri = await getCollection('galleri');
const settings = await getSiteSettings();

const images = import.meta.glob('/src/assets/galleri/*.{jpeg,jpg,png,webp}');

const sortert = [...galleri]
    .filter(item => (item.data.type ?? 'galleri') !== 'forsidebilde')
    .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

interface Props { variant?: SectionVariant; standalone?: boolean }
const { variant = 'white', standalone = false } = Astro.props;
const { sectionBg, headerBg } = getSectionClasses(variant);
---
{sortert.length > 0 && (
<section id="galleri" class={`section-container ${sectionBg}`}>
    <div class="section-content">
        <SectionHeader title={settings.galleriTittel} intro={settings.galleriTekst} headerBg={headerBg} />

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
            {sortert.map((item, index) => {
                const imgPath = `/src/assets/galleri/${item.data.image}`;
                const hasImage = item.data.image && images[imgPath];
                const mobileHidden = !standalone && sortert.length > 4 && index >= 4 ? 'hidden md:block' : '';
                const pX = item.data.imageConfig?.positionX ?? 50;
                const pY = item.data.imageConfig?.positionY ?? 50;
                const sc = item.data.imageConfig?.scale ?? 1.0;

                return (
                    <div class={`rounded-xl overflow-hidden shadow-sm aspect-[4/3] bg-brand-active relative group transition-all duration-300 hover:shadow-md ${mobileHidden}`}>
                        {hasImage ? (
                            <Image
                                src={images[imgPath]()}
                                alt={item.data.altText || item.data.title}
                                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                                style={{
                                    objectPosition: `${pX}% ${pY}%`,
                                    transform: `scale(${sc})`,
                                    transformOrigin: `${pX}% ${pY}%`
                                }}
                                loading="lazy"
                            />
                        ) : (
                            <div class="w-full h-full flex items-center justify-center text-brand-hover">
                                Bilde mangler
                            </div>
                        )}
                        {item.data.title && (
                            <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/60 to-transparent p-3 md:p-4">
                                <p class="text-white text-xs md:text-sm font-bold">{item.data.title}</p>
                            </div>
                        )}
                    </div>
                );
            })}
        </div>

        {!standalone && sortert.length > 4 && (
            <div class="mt-6 text-center">
                <a href="/galleri" class="text-brand-hover hover:text-brand font-medium text-sm transition-colors">
                    Se alle bilder →
                </a>
            </div>
        )}
    </div>
</section>
)}
