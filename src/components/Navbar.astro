---
import TelefonKnapp from "./TelefonKnapp.astro";
import {Image} from "astro:assets";
import logoImage from "../assets/tt-logo-2026.png";

interface Props { settings?: Record<string, string>; showGalleri?: boolean; }
const { settings = {}, showGalleri = true } = Astro.props;

const allNavLinks = [
    { name: 'Forside', href: '/', mobileHref: '/' },
    { name: settings.kontaktTittel || 'Kontakt', href: '/#kontakt', mobileHref: '/#kontakt' },
    { name: settings.galleriTittel || 'Klinikken vår', href: '/#galleri', mobileHref: '/galleri' },
    { name: settings.tjenesterTittel || 'Tjenester', href: '/#tjenester', mobileHref: '/tjenester' },
    { name: settings.tannlegerTittel || 'Om oss', href: '/#tannleger', mobileHref: '/tannleger' },
    { name: 'Prisliste', href: '/prisliste', mobileHref: '/prisliste' },
];

const navLinks = showGalleri ? allNavLinks : allNavLinks.filter(link => link.href !== '/#galleri');
---

<nav class="bg-white/95 backdrop-blur-sm supports-[backdrop-filter]:bg-white/80 border-b border-brand-border/60">
    <div class="layout-container">
        <div class="flex justify-between items-center h-16 lg:h-20">
            <a href="/" class="flex items-center no-underline">
                <Image
                        src={logoImage}
                        alt="Tenner og Trivsel"
                        width={256}
                        class="h-12 lg:h-16 w-auto object-contain"
                        loading="eager"
                />
            </a>

            <div class="hidden lg:flex items-center gap-6 xl:gap-8 whitespace-nowrap">
                {navLinks.map(link => (
                        <a href={link.href}
                           data-nav-link
                           class="nav-link">
                            {link.name}
                        </a>
                ))}
                <a id="admin-link-desktop" href="/admin" title="Admin" aria-label="Admin" class="nav-link hidden">
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
                    </svg>
                </a>
                <TelefonKnapp variant="secondary"/>
            </div>

            <button id="menu-btn" class="lg:hidden flex flex-col gap-1.5 p-2 text-brand-hover" aria-label="Meny" aria-expanded="false" aria-controls="mobile-menu">
                <span class="w-6 h-0.5 bg-current transition-all duration-300 origin-center"></span>
                <span class="w-6 h-0.5 bg-current transition-all duration-300"></span>
                <span class="w-6 h-0.5 bg-current transition-all duration-300 origin-center"></span>
            </button>
        </div>
    </div>

    <div id="mobile-menu" data-open="false" class="lg:hidden bg-white/95 backdrop-blur-sm border-t border-brand-border/60 absolute w-full left-0 shadow-xl z-50 transition-all duration-200 opacity-0 invisible pointer-events-none">
        <div class="flex flex-col p-6 gap-4">
            {navLinks.map(link => (
                    <a href={link.mobileHref} class="nav-link text-lg py-2 mobile-link border-b border-brand-light last:border-0">
                        {link.name}
                    </a>
            ))}
            <a id="admin-link-mobile" href="/admin" class="nav-link text-lg py-2 mobile-link border-b border-brand-light hidden">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 inline-block mr-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
                </svg>
                Admin
            </a>
            <TelefonKnapp variant="secondary" class="w-full"/>
        </div>
    </div>
</nav>

<script>
    import {initMobileMenu} from '../scripts/mobile-menu.js';
    import {initMenuHighlight} from '../scripts/menu-highlight.js';
    import {getStoredUser} from '../scripts/admin-auth.js';

    function init() {
        initMobileMenu();
        initMenuHighlight();

        const user = getStoredUser();
        if (user) {
            document.getElementById('admin-link-desktop')?.classList.remove('hidden');
            document.getElementById('admin-link-mobile')?.classList.remove('hidden');
        }
    }

    document.addEventListener('astro:page-load', init);
    init();
</script>