---
interface Props {
    href?: string;
    class?: string;
    variant?: 'primary' | 'secondary' | 'accent';
    target?: string;
    rel?: string;
    'aria-label'?: string;
    type?: 'button' | 'submit' | 'reset';
    disabled?: boolean;
    /** Sett til false for å rendre et ikke-interaktivt, ikke-fokuserbart <span>. */
    interactive?: boolean;
}

const { href, class: className, variant = 'primary', interactive = true, type, disabled, target, rel, ...rest } = Astro.props;

const Tag = !interactive ? 'span' : href ? 'a' : 'button';
// Gate interaktive attributter per tag så de ikke lekker til feil element
// (type/disabled hører kun til <button>, target/rel kun til <a>). For <a target="_blank">
// settes rel="noopener noreferrer" automatisk når rel ikke er eksplisitt angitt — hindrer
// reverse tabnabbing i eldre nettlesere (moderne setter noopener implisitt). target-sjekken
// er case-insensitiv (toLowerCase) fordi HTML-target er det — _BLANK må også dekkes.
const isButton = Tag === 'button';
const isAnchor = Tag === 'a';
const variantClasses: Record<string, string> = {
    primary: 'btn-primary',
    secondary: 'btn-secondary',
    accent: 'btn-accent',
};
const variantClass = variantClasses[variant] ?? 'btn-primary';
---

<Tag
        href={interactive ? href : undefined}
        type={isButton ? type : undefined}
        disabled={isButton ? disabled : undefined}
        target={isAnchor ? target : undefined}
        rel={isAnchor ? (rel ?? (target?.toLowerCase() === '_blank' ? 'noopener noreferrer' : undefined)) : undefined}
        class:list={[variantClass, className]}
        {...rest}
>
    <slot name="icon-left" />
    <slot />
    <slot name="icon-right" />
</Tag>
