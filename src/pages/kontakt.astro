---
import Layout from '../layouts/Layout.astro';
import { getSiteSettings } from '../scripts/getSettings';

import KontaktSide from '../components/Kontakt.astro';

const settings = await getSiteSettings();
---
<Layout
    title={`${settings.kontaktTittel} | Tenner og Trivsel`}
    description={settings.kontaktBeskrivelse}
>
    <KontaktSide variant="white" />
</Layout>
