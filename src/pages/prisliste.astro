---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import logoImage from '../assets/tt-logo-2026.png';

const rawPrisliste = await getCollection('prisliste');

const kategorier = new Map();
for (const item of rawPrisliste) {
    const key = item.data.kategori;
    if (!kategorier.has(key)) kategorier.set(key, []);
    kategorier.get(key).push(item.data);
}

const sistOppdatert = rawPrisliste[0]?.data.sistOppdatert || '';
let sistOppdatertTekst = '';
if (sistOppdatert) {
    const d = new Date(sistOppdatert);
    if (!isNaN(d.getTime())) {
        sistOppdatertTekst = d.toLocaleDateString('nb-NO', { month: 'long', year: 'numeric' });
    }
}

function formatPris(pris) {
    if (typeof pris === 'number') return `kr ${pris.toLocaleString('nb-NO')}`;
    return String(pris);
}
---
<Layout
    title="Prisliste | Tenner og Trivsel"
    description="Oversikt over priser for tannbehandlinger hos Tenner og Trivsel."
>
    <main class="section-container variant-white">
        <div class="section-content max-w-4xl mx-auto">
            <div class="print-logo hidden">
                <Image
                    src={logoImage}
                    alt="Tenner og Trivsel"
                    width={200}
                    class="h-12 w-auto object-contain"
                />
            </div>

            <div class="text-center mb-10">
                <h1 class="h1">Prisliste</h1>
                <p class="text-brand-hover mt-2 max-w-2xl mx-auto">
                    Prisene er veiledende og kan variere etter behandlingens omfang.
                </p>
                {sistOppdatertTekst && (
                    <p class="text-sm text-brand-hover/70 mt-1">Sist oppdatert: {sistOppdatertTekst}</p>
                )}
            </div>

            <div id="print-wrapper" class="flex justify-end mb-6 print:hidden" hidden>
                <button id="print-btn" class="btn-secondary text-sm py-2 px-4 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                    Skriv ut
                </button>
            </div>

            {kategorier.size === 0 && (
                <p class="text-center text-brand-hover italic py-12">Prislisten er tom.</p>
            )}

            <div class="space-y-6">
                {[...kategorier.entries()].map(([kategori, items]) => (
                    <div class="prisliste-kategori bg-white rounded-2xl border border-brand-border/60 shadow-sm overflow-hidden">
                        <div class="px-6 py-4 border-b border-brand-border/60">
                            <h2 class="font-heading font-bold text-xl md:text-2xl text-brand">{kategori}</h2>
                        </div>
                        <div class="px-6 py-2">
                            {items.map((item, i) => (
                                <div class:list={[
                                    "flex justify-between items-baseline py-3",
                                    i < items.length - 1 && "border-b border-brand-border/60"
                                ]}>
                                    <span class="text-base">{item.behandling}</span>
                                    <span class="font-semibold text-base whitespace-nowrap">{formatPris(item.pris)}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </main>
</Layout>

<style>
    @media print {
        nav, footer, .print\:hidden { display: none !important; }

        .print-logo {
            display: block !important;
            margin-bottom: 1rem;
        }

        main {
            padding: 0 !important;
        }

        .prisliste-kategori {
            box-shadow: none !important;
            border-radius: 0 !important;
            border-left: none !important;
            border-right: none !important;
            border-top: none !important;
            overflow: visible !important;
            break-inside: avoid;
        }
    }
</style>

<script>
    function isAdminLoggedIn() {
        for (const storage of [localStorage, sessionStorage]) {
            const stored = storage.getItem('admin_google_token');
            if (!stored) continue;
            try {
                const { expiry } = JSON.parse(stored);
                if (Date.now() < expiry - 60000) return true;
            } catch { /* ignore */ }
        }
        return false;
    }

    if (isAdminLoggedIn()) {
        document.getElementById('print-wrapper')?.removeAttribute('hidden');
    }

    document.getElementById('print-btn')?.addEventListener('click', () => window.print());
</script>
