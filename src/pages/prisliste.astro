---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import logoImage from '../assets/tt-logo-2026.png';
import fs from 'fs';
import path from 'path';
import { formatPris } from '../utils/format-pris.js';
import { findColumnSplitIndex } from '../utils/column-split.js';

const rawPrisliste = await getCollection('prisliste');

// Read category order from prisliste.json (top-level field set by sync-data)
let kategoriOrderMap = new Map();
try {
    const prislisteJson = JSON.parse(fs.readFileSync(path.join(process.cwd(), 'src/content/prisliste.json'), 'utf-8'));
    if (prislisteJson.kategoriOrder) {
        for (const k of prislisteJson.kategoriOrder) {
            kategoriOrderMap.set(k.kategori, k.order);
        }
    }
} catch { /* fallback to alphabetical */ }

const kategorier = new Map();
for (const item of rawPrisliste) {
    const key = item.data.kategori;
    if (!kategorier.has(key)) kategorier.set(key, []);
    kategorier.get(key).push(item.data);
}
for (const items of kategorier.values()) {
    items.sort((a, b) => (a.order ?? 0) - (b.order ?? 0) || (a.tjeneste ?? '').localeCompare(b.tjeneste ?? '', 'nb'));
}

// Sort categories by kategoriOrder, fallback to alphabetical
const sortedKategorier = new Map(
    [...kategorier.entries()].sort(([a], [b]) => {
        const orderA = kategoriOrderMap.get(a) ?? Number.MAX_SAFE_INTEGER;
        const orderB = kategoriOrderMap.get(b) ?? Number.MAX_SAFE_INTEGER;
        if (orderA !== orderB) return orderA - orderB;
        return a.localeCompare(b, 'nb');
    })
);

const categoryList = [...sortedKategorier.entries()].map(([kategori, items]) => ({
    kategori,
    items,
    rows: items.length + 1,
}));
const columnSplitIndex = findColumnSplitIndex(categoryList);

const sistOppdatert = rawPrisliste.reduce((max, item) =>
    item.data.sistOppdatert > max ? item.data.sistOppdatert : max, '');
let sistOppdatertTekst = '';
if (sistOppdatert) {
    const d = new Date(sistOppdatert);
    if (!isNaN(d.getTime())) {
        sistOppdatertTekst = d.toLocaleDateString('nb-NO', { month: 'long', year: 'numeric' });
    }
}

---
<Layout
    title="Prisliste | Tenner og Trivsel"
    description="Oversikt over priser for tannbehandlinger hos Tenner og Trivsel."
>
    <div class="section-container variant-white">
        <div class="section-content max-w-4xl mx-auto">
            <div class="prisliste-header-print not-print">
                <Image
                    src={logoImage}
                    alt="Tenner og Trivsel"
                    width={280}
                    class="print-header-logo"
                    loading="eager"
                />
                <div class="prisliste-header-text">
                    <h1 class="prisliste-tittel-print">Prisliste</h1>
                    <p class="prisliste-undertekst-print">
                        Prisene er veiledende og kan variere etter behandlingens omfang.
                    </p>
                    {sistOppdatertTekst && (
                        <p class="prisliste-dato-print">Sist oppdatert: {sistOppdatertTekst}</p>
                    )}
                </div>
            </div>

            <div class="text-center mb-10 prisliste-header-web">
                <h1 class="h1 prisliste-tittel">Prisliste</h1>
                <p class="text-brand-hover mt-2 max-w-2xl mx-auto prisliste-undertekst">
                    Prisene er veiledende og kan variere etter behandlingens omfang.
                </p>
                {sistOppdatertTekst && (
                    <p class="text-sm text-brand-hover/70 mt-1 prisliste-dato">Sist oppdatert: {sistOppdatertTekst}</p>
                )}
            </div>

            {kategorier.size === 0 && (
                <p class="text-center text-brand-hover italic py-12">Prislisten er tom.</p>
            )}

            {/* Web: enkel kolonne */}
            <div class="prisliste-web space-y-6">
                {categoryList.map(({ kategori, items }) => (
                    <div class="prisliste-kategori bg-white rounded-2xl border border-brand-border/60 shadow-sm overflow-hidden">
                        <div class="px-6 py-4 border-b border-brand-border/60">
                            <h2 class="font-heading font-bold text-xl md:text-2xl text-brand">{kategori}</h2>
                        </div>
                        <div class="px-6 py-2">
                            {items.map((item, i) => (
                                <div class:list={[
                                    "prisliste-rad",
                                    i < items.length - 1 && "border-b border-brand-border/60"
                                ]}>
                                    <span class="prisliste-behandling text-sm">{item.behandling}</span>
                                    <span class="prisliste-leader" aria-hidden="true"></span>
                                    <span class="prisliste-pris text-sm whitespace-nowrap">{formatPris(item.pris)}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>

            {/* Print: to eksplisitte kolonner via grid */}
            <div class="prisliste-print">
                <div class="print-kolonne">
                    {categoryList.slice(0, columnSplitIndex).map(({ kategori, items }) => (
                        <div class="prisliste-kategori">
                            <h2>{kategori}</h2>
                            <div>
                                {items.map((item, i) => (
                                    <div class:list={["print-rad", i < items.length - 1 && "print-rad-border"]}>
                                        <span>{item.behandling}</span>
                                        <span class="whitespace-nowrap">{formatPris(item.pris)}</span>
                                    </div>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
                <div class="print-kolonne">
                    {categoryList.slice(columnSplitIndex).map(({ kategori, items }) => (
                        <div class="prisliste-kategori">
                            <h2>{kategori}</h2>
                            <div>
                                {items.map((item, i) => (
                                    <div class:list={["print-rad", i < items.length - 1 && "print-rad-border"]}>
                                        <span>{item.behandling}</span>
                                        <span class="whitespace-nowrap">{formatPris(item.pris)}</span>
                                    </div>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</Layout>

<style is:global>
    .not-print { display: none; }
    .prisliste-print { display: none; }

    .prisliste-rad {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        padding: 0.75rem 0;
    }

    .prisliste-behandling {
        flex-shrink: 1;
    }

    .prisliste-leader {
        flex: 1;
        border-bottom: 1px dotted var(--color-brand-border);
        min-width: 1.5rem;
        position: relative;
        top: -0.25em;
    }

    .prisliste-pris {
        flex-shrink: 0;
    }

    @page {
        size: landscape;
        margin: 0;
    }

    @media print {
        nav, footer, .skip-link, #navbar-sticky-wrapper, #banner-root,
        .print\:hidden { display: none !important; }

        .not-print { display: flex !important; }

        /* Skjul web-layout, vis print-layout */
        .prisliste-web { display: none !important; }
        .prisliste-print { display: grid !important; }
        .prisliste-header-web { display: none !important; }

        html, body {
            margin: 0 !important;
            padding: 0 !important;
        }

        body {
            padding: 0.5cm 1.2cm !important;
            min-height: auto !important;
            font-size: 8pt;
            line-height: 1.25;
        }

        main, .section-container, .section-content {
            padding: 0 !important;
            margin: 0 !important;
            max-width: none !important;
        }

        /* Print header: én kompakt linje */
        .prisliste-header-print {
            display: flex !important;
            align-items: center;
            gap: 0.3cm;
            margin-bottom: 0.35cm;
            padding-bottom: 0.15cm;
            border-bottom: 1px solid var(--color-brand);
        }
        .print-header-logo {
            height: 0.8cm;
            width: auto;
            flex-shrink: 0;
        }
        .prisliste-header-text {
            flex: 1;
            display: flex;
            align-items: baseline;
            gap: 0.3cm;
        }
        .prisliste-tittel-print {
            font-size: 12pt;
            font-weight: 900;
            font-family: var(--font-heading);
            margin: 0;
            line-height: 1;
        }
        .prisliste-undertekst-print {
            font-size: 6pt;
            color: var(--color-brand-hover);
            margin: 0;
        }
        .prisliste-dato-print {
            font-size: 6pt;
            color: var(--color-brand-hover);
            margin: 0;
            margin-left: auto;
        }

        /* To-kolonners grid */
        .prisliste-print {
            grid-template-columns: 1fr 1fr;
            gap: 0 0.8cm;
            align-items: start;
        }

        .prisliste-kategori {
            margin-bottom: 0.2cm;
        }

        .prisliste-kategori h2 {
            font-size: 8.5pt;
            font-weight: bold;
            font-family: var(--font-heading);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 0.1cm 0 0.05cm 0;
            margin: 0;
            border-bottom: 1px solid var(--color-brand);
        }

        .print-rad {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            padding: 0.04cm 0;
            font-size: 8pt;
        }

        .print-rad-border {
            border-bottom: 0.5px solid var(--color-brand-border);
        }
    }
</style>

<script is:inline>
    if (new URLSearchParams(window.location.search).has('print')) {
        var hasToken = localStorage.getItem('admin_google_token') || sessionStorage.getItem('admin_google_token');
        if (hasToken) {
            window.addEventListener('load', function () {
                window.print();
            });
        }
    }
</script>

