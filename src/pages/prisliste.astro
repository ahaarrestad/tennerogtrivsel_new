---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import logoImage from '../assets/tt-logo-2026.png';

const rawPrisliste = await getCollection('prisliste');

const kategorier = new Map();
for (const item of rawPrisliste) {
    const key = item.data.kategori;
    if (!kategorier.has(key)) kategorier.set(key, []);
    kategorier.get(key).push(item.data);
}
for (const items of kategorier.values()) {
    items.sort((a, b) => (a.order ?? 0) - (b.order ?? 0));
}

const sistOppdatert = rawPrisliste.reduce((max, item) =>
    item.data.sistOppdatert > max ? item.data.sistOppdatert : max, '');
let sistOppdatertTekst = '';
if (sistOppdatert) {
    const d = new Date(sistOppdatert);
    if (!isNaN(d.getTime())) {
        sistOppdatertTekst = d.toLocaleDateString('nb-NO', { month: 'long', year: 'numeric' });
    }
}

function formatPris(pris) {
    if (typeof pris === 'number') return `kr ${pris.toLocaleString('nb-NO')}`;
    return String(pris);
}
---
<Layout
    title="Prisliste | Tenner og Trivsel"
    description="Oversikt over priser for tannbehandlinger hos Tenner og Trivsel."
>
    <main class="section-container variant-white">
        <div class="section-content max-w-4xl mx-auto">
            <div class="prisliste-header-print not-print">
                <Image
                    src={logoImage}
                    alt="Tenner og Trivsel"
                    width={280}
                    class="print-header-logo"
                    loading="eager"
                />
                <div class="prisliste-header-text">
                    <h1 class="prisliste-tittel-print">Prisliste</h1>
                    <p class="prisliste-undertekst-print">
                        Prisene er veiledende og kan variere etter behandlingens omfang.
                    </p>
                    {sistOppdatertTekst && (
                        <p class="prisliste-dato-print">Sist oppdatert: {sistOppdatertTekst}</p>
                    )}
                </div>
            </div>

            <div class="text-center mb-10 prisliste-header-web">
                <h1 class="h1 prisliste-tittel">Prisliste</h1>
                <p class="text-brand-hover mt-2 max-w-2xl mx-auto prisliste-undertekst">
                    Prisene er veiledende og kan variere etter behandlingens omfang.
                </p>
                {sistOppdatertTekst && (
                    <p class="text-sm text-brand-hover/70 mt-1 prisliste-dato">Sist oppdatert: {sistOppdatertTekst}</p>
                )}
            </div>

            {kategorier.size === 0 && (
                <p class="text-center text-brand-hover italic py-12">Prislisten er tom.</p>
            )}

            <div class="space-y-6 print:space-y-0">
                {[...kategorier.entries()].map(([kategori, items]) => (
                    <div class="prisliste-kategori bg-white rounded-2xl border border-brand-border/60 shadow-sm overflow-hidden">
                        <div class="px-6 py-4 border-b border-brand-border/60">
                            <h2 class="font-heading font-bold text-xl md:text-2xl text-brand">{kategori}</h2>
                        </div>
                        <div class="px-6 py-2">
                            {items.map((item, i) => (
                                <div class:list={[
                                    "flex justify-between items-baseline py-3",
                                    i < items.length - 1 && "border-b border-brand-border/60"
                                ]}>
                                    <span class="text-base">{item.behandling}</span>
                                    <span class="font-semibold text-base whitespace-nowrap">{formatPris(item.pris)}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </main>
</Layout>

<style is:global>
    .not-print { display: none; }

    @page {
        margin: 0;
    }

    @media print {
        /* Skjul ALT fra layout utenom prisliste-innholdet */
        nav, footer, .skip-link, #navbar-sticky-wrapper, #banner-root,
        .print\:hidden { display: none !important; }

        .not-print { display: flex !important; }

        html, body {
            margin: 0 !important;
            padding: 0 !important;
        }

        body {
            padding: 1cm 2cm !important;
            min-height: auto !important;
        }

        main, .section-container, .section-content {
            padding: 0 !important;
            margin: 0 !important;
            max-width: none !important;
        }

        /* Skjul web-headeren i print */
        .prisliste-header-web {
            display: none !important;
        }

        /* Print header: logo venstre, tekst høyre — kompakt */
        .prisliste-header-print {
            display: flex !important;
            align-items: center;
            gap: 0.6cm;
            margin-bottom: 0.5cm;
            padding-bottom: 0.3cm;
        }
        .print-header-logo {
            height: 1.2cm;
            width: auto;
            flex-shrink: 0;
        }
        .prisliste-header-text {
            flex: 1;
        }
        .prisliste-tittel-print {
            font-size: 18pt;
            font-weight: 900;
            font-family: var(--font-heading);
            margin: 0;
            line-height: 1.2;
        }
        .prisliste-undertekst-print {
            font-size: 9pt;
            color: var(--color-brand-hover);
            margin: 0.05cm 0 0;
        }
        .prisliste-dato-print {
            font-size: 8pt;
            color: var(--color-brand-hover);
            margin: 0.05cm 0 0;
        }

        /* Kategorikort */
        .prisliste-kategori {
            box-shadow: none !important;
            border-radius: 0 !important;
            border: none !important;
            overflow: visible !important;
            break-inside: avoid;
        }

        .prisliste-kategori h2 {
            font-size: 11pt;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 0.2cm 0 0.1cm 0;
            border-bottom: 1px solid var(--color-brand);
        }

        .prisliste-kategori > div:last-child {
            padding: 0;
        }
    }
</style>

<script is:inline>
    if (new URLSearchParams(window.location.search).has('print')) {
        window.addEventListener('load', function () {
            window.print();
        });
    }
</script>

