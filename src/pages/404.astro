---
import Layout from "../layouts/Layout.astro";
import TelefonKnapp from "../components/TelefonKnapp.astro";
---

<Layout title="Siden ble ikke funnet | Tenner og Trivsel">
    <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden bg-white">

        {/* Stor, blek 404 som bakgrunnselement */}
        <div class="absolute inset-0 flex items-center justify-center select-none pointer-events-none" aria-hidden="true">
            <span class="text-[12rem] md:text-[20rem] font-black text-brand-active leading-none tracking-tight">404</span>
        </div>

        <div class="section-content relative z-10">
            <div class="max-w-xl mx-auto text-center">
                <h1 class="h2 mb-4">Karies i systemet?</h1>

                <p class="section-intro mb-10">
                    Denne siden har dessverre fått et <strong>alvorlig hull</strong>.
                    Vi har prøvd med både sondering og røntgen, men konklusjonen er
                    at lenken må trekkes.
                </p>

                <div class="flex flex-col sm:flex-row gap-4 justify-center items-stretch sm:items-center">
                    <a href="/" class="btn-primary">Til forsiden</a>
                    <TelefonKnapp variant="secondary" />
                </div>
            </div>
        </div>
    </section>
</Layout>
