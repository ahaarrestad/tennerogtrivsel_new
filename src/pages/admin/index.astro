---
// src/pages/admin/index.astro
import '../../styles/global.css';
import { Image } from "astro:assets";
import logoImage from "../../assets/tt-logo-2026.png";
import { HARD_DEFAULTS } from '../../scripts/getSettings';

const TJENESTER_FOLDER = import.meta.env.PUBLIC_GOOGLE_DRIVE_TJENESTER_FOLDER_ID;
const TANNLEGER_FOLDER = import.meta.env.PUBLIC_GOOGLE_DRIVE_TANNLEGER_FOLDER_ID;
const MELDINGER_FOLDER = import.meta.env.PUBLIC_GOOGLE_DRIVE_MELDINGER_FOLDER_ID;
const BILDER_FOLDER = import.meta.env.PUBLIC_GOOGLE_DRIVE_BILDER_FOLDER_ID;
---
<!doctype html>
<html lang="no" class="h-full bg-admin-surface">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>Admin | Tenner og Trivsel</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="manifest" href="/admin-manifest.json">
    <meta name="theme-color" content="#292524">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="TT Admin">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <script src="https://apis.google.com/js/api.js" async defer></script>
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    
    <!-- Editor & Datepicker assets (pinned versions + SRI) -->
    <link rel="stylesheet" href="https://unpkg.com/easymde@2.20.0/dist/easymde.min.css" integrity="sha384-3AvV7152TgYAMYdGZPqG9BpmSH2ZW6ewTDL0QV5PyNkl19KMI+yLMdJz183N8A2d" crossorigin="anonymous">
    <script src="https://unpkg.com/easymde@2.20.0/dist/easymde.min.js" integrity="sha384-YDXeUfPZ4SP6vJpnF+ZMmf4B1bax6yd4Q/aNbkvLidRD843hPG5RE67M0IYT4LOq" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css" integrity="sha384-RkASv+6KfBMW9eknReJIJ6b3UnjKOKC5bOUaNgIY778NFbQ8MtWq9Lr/khUgqtTt" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13" integrity="sha384-5JqMv4L/Xa0hfvtF06qboNdhvuYXUku9ZrhZh3bSk8VXF0A/RuSLHpLsSV9Zqhl6" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/l10n/no.js" integrity="sha384-UOy25oJXKTxZ3z0Um6Yb4fWFI5XUD2EyyvYe66gTjPVh8m++j41++hDI0V/8nel6" crossorigin="anonymous"></script>

    <!-- Icons for EasyMDE -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" integrity="sha384-wvfXpqpZZVQGK6TAh5PVlGOfQNHSoD2xbE+QkPxCAFlNEevoEH3Sl0sibVcOQVnN" crossorigin="anonymous">

    <style is:global>
        .EasyMDEContainer .editor-toolbar {
            border-top-left-radius: 12px;
            border-top-right-radius: 12px;
            border-color: var(--color-admin-border);
            background: var(--color-admin-surface);
        }
        .EasyMDEContainer .CodeMirror {
            border-bottom-left-radius: 12px;
            border-bottom-right-radius: 12px;
            border-color: var(--color-admin-border);
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        }
        .EasyMDEContainer .editor-preview-active-side {
            border-color: var(--color-admin-border);
        }
    </style>
</head>
<body class="admin-layout">

    <!-- ADMIN NAVIGASJON -->
    <nav class="admin-nav">
        <div class="admin-nav-container">
            <!-- VENSTRE: Logo & Admin-tittel -->
            <a href="/" class="admin-logo-container group">
                <Image
                        src={logoImage}
                        alt="Tenner og Trivsel"
                        width={256}
                        class="h-14 sm:h-20 w-auto object-contain shrink-0"
                        loading="eager"
                />
                <div class="flex flex-col justify-center leading-none whitespace-nowrap overflow-hidden">
                    <span class="text-base sm:text-xl font-black uppercase tracking-tighter text-brand">Admin</span>
                </div>
            </a>

            <!-- HØYRE: Bruker-info & Hjem-link -->
            <div class="flex items-center gap-2 sm:gap-6 shrink-0">
                <button id="user-pill"
                        style="display: none;"
                        class="admin-user-pill group cursor-pointer whitespace-nowrap">
                    <span id="nav-user-info" class="text-[10px] sm:text-sm font-bold text-brand truncate max-w-[60px] xs:max-w-[100px] sm:max-w-none min-w-0 pointer-events-none"></span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-admin-muted-light group-hover:text-brand shrink-0 pointer-events-none ml-1"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                </button>
                
                <a href="/" aria-label="Hjem" class="text-brand font-black flex flex-row flex-nowrap items-center gap-1 hover:text-brand-hover transition-colors text-[10px] sm:text-sm shrink-0 whitespace-nowrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                    <span class="hidden sm:inline uppercase tracking-wider">Hjem</span>
                </a>
            </div>
        </div>
    </nav>

    <main class="flex-grow flex flex-col items-center p-4">
        <!-- LOGIN CONTAINER -->
        <div id="login-container" class="admin-login-box my-auto">
            <div class="space-y-4">
                <Image src={logoImage} alt="Tenner og Trivsel" width={240} class="h-20 sm:h-24 w-auto object-contain mx-auto" loading="eager" />
                <h1 class="admin-title">Velkommen</h1>
                <p class="text-admin-muted">Logg inn for å administrere innholdet på nettsiden.</p>
            </div>

            <div class="flex items-center gap-2">
                <input type="checkbox" id="remember-me"
                    class="w-4 h-4 accent-brand cursor-pointer rounded" />
                <label for="remember-me" class="text-sm text-admin-muted cursor-pointer select-none">
                    Husk meg i denne nettleseren
                </label>
            </div>

            <button id="login-btn" class="btn-primary w-full py-4 flex items-center justify-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 48 48">
                    <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24s8.955,20,20,20s20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
                    <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
                    <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/>
                    <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
                </svg>
                Logg inn med Google
            </button>
            <p class="text-xs text-admin-muted text-center mt-2">
                Ved innlogging lagres autentiseringstoken i nettleseren din.
                <a href="/personvern" class="underline hover:text-white transition-colors">Les vår personvernerklæring</a>.
            </p>
        </div>

        <!-- LOADING CONTAINER -->
        <div id="loading-container" class="hidden admin-login-box my-auto">
            <div class="flex flex-col items-center gap-4">
                <svg class="animate-spin h-10 w-10 text-brand" aria-hidden="true" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <p class="text-admin-muted text-sm">Verifiserer tilgang...</p>
            </div>
        </div>

        <!-- NO ACCESS CONTAINER -->
        <div id="no-access-container" class="hidden admin-login-box my-auto">
            <div class="space-y-4 text-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-admin-muted-light"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                <h1 class="admin-title">Ingen tilgang</h1>
                <p class="text-admin-muted">Denne kontoen har ikke tilgang til admin-panelet, eller noe gikk galt. Prøv å logge inn med en annen konto.</p>
            </div>
            <button id="no-access-switch-btn" class="btn-primary w-full py-4">
                Logg inn med annen konto
            </button>
        </div>

        <!-- DASHBOARD CONTAINER -->
        <div id="dashboard" class="hidden admin-dashboard-container">
            <header class="admin-card-header">
                <h1 class="admin-title">Behandlingsrommet</h1>
                <p class="admin-info-text">Her pleier vi innholdet slik at nettsiden alltid viser seg fra sin beste side.</p>
                <p class="admin-info-text !not-italic text-xs text-admin-muted-light mt-1">Endringer lagres på Google Disk og publiseres automatisk innen noen minutter.</p>
            </header>

            <div class="admin-module-grid">
                <div id="card-settings" class="admin-card-interactive group" role="link" tabindex="0" aria-label="Gå til Rutinesjekken">
                    <h2 class="admin-subtitle group-hover:text-brand-hover">Rutinesjekken</h2>
                    <p class="admin-description">Telefonnumre, åpningstider og nettsidetitler.</p>
                    <span class="admin-card-chevron" aria-hidden="true">&rsaquo;</span>
                </div>
                <div id="card-tjenester" class="admin-card-interactive group" role="link" tabindex="0" aria-label="Gå til Finpussen">
                    <h2 class="admin-subtitle group-hover:text-brand-hover">Finpussen</h2>
                    <p class="admin-description">Rediger tekst og innhold for tannhelsetjenestene.</p>
                    <span id="card-tjenester-count" class="admin-card-count"></span>
                    <span class="admin-card-chevron" aria-hidden="true">&rsaquo;</span>
                </div>
                <div id="card-meldinger" class="admin-card-interactive group" role="link" tabindex="0" aria-label="Gå til Oppslagstavla">
                    <h2 class="admin-subtitle group-hover:text-brand-hover">Oppslagstavla</h2>
                    <p class="admin-description">Lag og administrer aktive meldinger og infobannere.</p>
                    <span id="card-meldinger-count" class="admin-card-count"></span>
                    <span class="admin-card-chevron" aria-hidden="true">&rsaquo;</span>
                </div>
                <div id="card-tannleger" class="admin-card-interactive group" role="link" tabindex="0" aria-label="Gå til Tannlegekrakken">
                    <h2 class="admin-subtitle group-hover:text-brand-hover">Tannlegekrakken</h2>
                    <p class="admin-description">Oppdater ansattinfo og last opp nye portretter.</p>
                    <span id="card-tannleger-count" class="admin-card-count"></span>
                    <span class="admin-card-chevron" aria-hidden="true">&rsaquo;</span>
                </div>
                <div id="card-bilder" class="admin-card-interactive group" role="link" tabindex="0" aria-label="Gå til Røntgenbildene">
                    <h2 class="admin-subtitle group-hover:text-brand-hover">Røntgenbildene</h2>
                    <p class="admin-description">Forsidebilde og galleri med zoom og utsnitt.</p>
                    <span id="card-bilder-count" class="admin-card-count"></span>
                    <span class="admin-card-chevron" aria-hidden="true">&rsaquo;</span>
                </div>
                <div id="card-prisliste" class="admin-card-interactive group" role="link" tabindex="0" aria-label="Gå til Takstlista">
                    <h2 class="admin-subtitle group-hover:text-brand-hover">Takstlista</h2>
                    <p class="admin-description">Administrer priser for alle behandlinger.</p>
                    <span id="card-prisliste-count" class="admin-card-count"></span>
                    <span class="admin-card-chevron" aria-hidden="true">&rsaquo;</span>
                </div>
            </div>
        </div>

        <!-- MODUL-SEKSJONER -->
        <div id="module-container" class="hidden admin-dashboard-container">
            <div class="flex justify-between items-center">
                <nav aria-label="Brødsmule" class="admin-breadcrumb">
                    <button id="back-to-dashboard" class="admin-breadcrumb-back" aria-label="Tilbake til dashboard">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                        Dashboard
                    </button>
                    <span class="admin-breadcrumb-sep" aria-hidden="true">/</span>
                    <button id="breadcrumb-module" class="admin-breadcrumb-current"></button>
                    <span id="breadcrumb-count" class="admin-item-count"></span>
                    <span id="breadcrumb-editor-sep" class="admin-breadcrumb-sep hidden" aria-hidden="true">/</span>
                    <span id="breadcrumb-editor" class="admin-breadcrumb-current hidden"></span>
                </nav>
                <div id="module-actions"></div>
            </div>
            
            <div id="module-content" class="admin-card min-h-[300px]">
                <h2 id="module-title" class="admin-title !mb-8 border-b border-brand-light pb-6">Behandlingsområde</h2>
                <div id="module-inner">
                    <div class="flex items-center gap-3 text-admin-muted text-sm italic" role="status" aria-label="Laster innhold">
                        <svg class="animate-spin h-5 w-5" aria-hidden="true" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        Laster innhold...
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- IMAGE PICKER MODAL -->
    <dialog id="image-picker-modal" class="p-0 rounded-2xl shadow-2xl backdrop:bg-black/50 backdrop:backdrop-blur-sm w-[90vw] max-w-4xl max-h-[85vh]">
        <div class="flex flex-col h-full max-h-[85vh]">
            <div class="p-6 border-b border-admin-hover flex justify-between items-center bg-white sticky top-0 z-10">
                <h3 class="text-lg font-black uppercase tracking-tight text-brand">Velg bilde</h3>
                <button onclick="document.getElementById('image-picker-modal').close()" class="p-2 rounded-lg text-admin-muted-light hover:text-admin-muted hover:bg-admin-hover transition-colors cursor-pointer" aria-label="Lukk">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            
            <div class="p-6 bg-admin-surface overflow-y-auto grow">
                <!-- UPLOAD SECTION -->
                <div class="mb-8">
                    <label for="upload-image-input" class="flex flex-col items-center justify-center w-full h-32 border-2 border-admin-border border-dashed rounded-xl cursor-pointer bg-white hover:bg-admin-surface transition-colors group relative">
                        <div id="upload-preview" class="flex flex-col items-center justify-center pt-5 pb-6 transition-opacity duration-200">
                            <svg class="w-8 h-8 mb-3 text-admin-muted-light group-hover:text-brand transition-colors" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 16">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 13h3a3 3 0 0 0 0-6h-.025A5.56 5.56 0 0 0 16 6.5 5.5 5.5 0 0 0 5.207 5.021C5.137 5.017 5.071 5 5 5a4 4 0 0 0 0 8h2.167M10 15V6m0 0L8 8m2-2 2 2"/>
                            </svg>
                            <p class="mb-2 text-sm text-admin-muted"><span class="font-bold text-brand">Klikk for å laste opp</span> eller dra og slipp</p>
                            <p class="text-xs text-admin-muted-light">JPG, PNG, WEBP (Maks 5MB)</p>
                        </div>
                        <div id="upload-spinner" class="absolute inset-0 flex items-center justify-center bg-white/80 hidden" role="status" aria-label="Laster opp bilde">
                            <svg class="animate-spin h-8 w-8 text-brand" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        </div>
                        <input id="upload-image-input" type="file" class="hidden" accept="image/*" />
                    </label>
                </div>

                <!-- GALLERY GRID -->
                <div>
                    <h4 class="text-xs font-black uppercase tracking-widest text-admin-muted-light mb-4">Bilder på Google Drive</h4>
                    <div id="image-gallery-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
                        <!-- Bilder lastes inn her via JS -->
                    </div>
                </div>
            </div>
        </div>
    </dialog>

    <div id="admin-config"
         data-tjenester-folder={TJENESTER_FOLDER}
         data-tannleger-folder={TANNLEGER_FOLDER}
         data-meldinger-folder={MELDINGER_FOLDER}
         data-bilder-folder={BILDER_FOLDER}
         data-sheet-id={import.meta.env.PUBLIC_GOOGLE_SHEET_ID}
         data-defaults={JSON.stringify(HARD_DEFAULTS)}
         class="hidden"></div>

    <script>
        import '../../scripts/admin-init.js';
    </script>
</body>
</html>
