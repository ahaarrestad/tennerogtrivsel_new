---
import {getCollection, render} from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TelefonKnapp from "../../components/TelefonKnapp.astro";
import ContactButton from "../../components/ContactButton.astro";
import KontaktKnapp from "../../components/KontaktKnapp.astro";
import { slugify } from '../../scripts/slugify';

// 1. Generer stier for alle tjenestene
export async function getStaticPaths() {
    const tjenesteEntries = await getCollection('tjenester');
    return tjenesteEntries
        .filter(entry => entry.data.active !== false)
        .map(entry => ({
            params: {id: slugify(entry.data.title)},
            props: {entry},
        }));
}

// 2. Hent data for den spesifikke siden
const {entry} = Astro.props;
const {Content} = await render(entry);

const tjenester = (await getCollection('tjenester')).filter(s => s.data.active !== false);
const currentSlug = slugify(entry.data.title);
---
<Layout title={`${entry.data.title} | Tenner og Trivsel`} description={entry.data.ingress}>
    <div class="flex-grow bg-white w-full">

        <section class="pt-12 md:pt-20 pb-0">
            <div class="max-w-6xl mx-auto px-4 w-full">
                <nav class="mb-8 text-sm text-brand-hover" aria-label="Brødsmulesti">
                    <a href="/" class="hover:text-brand transition-colors">Forside</a>
                    <span class="mx-2">/</span>
                    <a href="/tjenester" class="hover:text-brand transition-colors">Tjenester</a>
                    <span class="mx-2">/</span>
                    <span class="text-brand font-medium">{entry.data.title}</span>
                </nav>

                <div class="flex flex-wrap xl:flex-nowrap gap-12 items-start">

                    <div class="flex-1 min-w-0">

                        <header class="mb-12 not-prose">
                            <h1 class="h2 text-left" style="max-width: none;">
                                {entry.data.title}
                            </h1>

                            <p class="font-body text-brand-hover text-base md:text-lg leading-relaxed italic mt-2">
                                {entry.data.ingress}
                            </p>
                        </header>

                        <div class="markdown-content prose max-w-none">
                            <Content/>
                        </div>
                    </div>

                    <aside class="w-full lg:w-80 xl:w-96 lg:sticky lg:top-24 min-w-fit">
                        <div class="p-6 md:p-8 bg-brand-light rounded-2xl border border-brand-border/60 shadow-sm flex flex-col gap-4">
                            <h3 class="card-title text-lg leading-snug" style="margin-bottom: 0;">
                                Ta kontakt med oss for mer informasjon
                            </h3>
                            <div class="flex flex-col gap-3 relative z-10">
                                <TelefonKnapp variant="accent"/>
                                <ContactButton variant="accent"/>
                            </div>
                            <KontaktKnapp class="w-full"/>
                        </div>
                    </aside>
                </div>

                <div class="mt-16 mb-20 border-t border-brand-border/60 pt-8">
                    <h4 class="font-heading font-bold mb-6 text-brand text-sm uppercase tracking-wide">
                        Våre tjenester
                    </h4>
                    <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-3">
                        {tjenester
                            .toSorted((a, b) => (a.data.priority ?? 99) - (b.data.priority ?? 99) || a.data.title.localeCompare(b.data.title, 'nb'))
                            .map(s => {
                                const slug = slugify(s.data.title);
                                const isCurrent = slug === currentSlug;
                                return (
                                        <li class="flex items-center gap-2 py-1">
                                            <span class={isCurrent ? "text-brand-hover font-bold" : "text-brand"}>→</span>
                                            {isCurrent ? (
                                                    <span class="text-sm font-bold text-brand-hover">{s.data.title}</span>
                                            ) : (
                                                    <a href={`/tjenester/${slug}`}
                                                       class="text-sm font-medium text-brand hover:text-brand-hover transition-colors">
                                                        {s.data.title}
                                                    </a>
                                            )}
                                        </li>
                                );
                            })
                        }
                    </ul>
                </div>
            </div>
        </section>
    </div>
</Layout>
