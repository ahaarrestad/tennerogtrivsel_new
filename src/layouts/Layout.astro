---
export interface Props {
    title?: string;
    description?: string;
    canonical?: string;
}
import Footer from '../components/Footer.astro';
import '../styles/global.css';

import InfoBanner from '../components/InfoBanner.astro';
import Navbar from '../components/Navbar.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { getSiteSettings } from '../scripts/getSettings';
import { getCollection } from 'astro:content';

const settings = await getSiteSettings();
const galleri = await getCollection('galleri');
const showGalleri = galleri.some(item => (item.data.type ?? 'galleri') !== 'forsidebilde');

const {
    title = settings.siteTitle,
    description = settings.siteDescription,
    canonical
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="no" class="scroll-smooth h-full">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width"/>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png">
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL('/hovedbilde.png', Astro.site).href} />
    <meta property="og:locale" content="nb_NO" />
    <meta property="og:site_name" content="Tenner og Trivsel" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/hovedbilde.png', Astro.site).href} />

    <SchemaOrg settings={settings} />
</head>

<body class="text-brand flex flex-col min-h-full">

<a href="#main-content" class="skip-link">Hopp til hovedinnhold</a>

<InfoBanner/>


<div id="navbar-sticky-wrapper" class="sticky top-0 z-50 transition-all duration-300">
    <Navbar settings={settings} showGalleri={showGalleri} />
</div>

<main id="main-content" class="flex-grow flex flex-col">
    <slot/>
</main>

<Footer/>

<script>
    import { initLayoutHelper } from '../scripts/layout-helper.js';
    
    document.addEventListener('astro:page-load', initLayoutHelper);
    initLayoutHelper();
</script>

</body>
</html>

